<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Maps"
    android:background="@drawable/background1">


    <ImageView
        android:id="@+id/k"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/_0_4316"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />



    <TextView
        android:id="@+id/textView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="220dp"
        android:gravity="center"
        android:text="Alamat Kantor"
        android:textColor="?attr/colorOnPrimary"
        android:textSize="20dp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/k" />

    <ImageView
        android:id="@+id/pin1"
        android:layout_marginLeft="20dp"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginTop="10dp"
        android:src="@drawable/location_map_pin_mark_icon_148685"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <ImageView
        android:id="@+id/laporan"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:layout_marginTop="5dp"
        android:src="@drawable/logo_sp4n"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/garis1" />

    <TextView
        android:layout_width="60dp"
        android:layout_height="20dp"
        android:text="Lapor"
        android:textColor="?attr/colorOnPrimary"
        android:textSize="16dp"
        android:textStyle="bold"
        android:id="@+id/laporan1"
        android:textAlignment="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/laporan" />

    <TextView
        android:id="@+id/alamt"
        android:layout_width="290dp"
        android:layout_height="wrap_content"
        android:text="@string/alamat"
        android:textAlignment="center"
        android:textColor="?attr/colorOnPrimary"
        android:textSize="16dp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/pin1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/pin1"
        app:layout_constraintStart_toEndOf="@+id/pin1"
        app:layout_constraintTop_toTopOf="@id/pin1"
        app:layout_constraintVertical_bias="1.0" />

    <ImageView
        android:id="@+id/pin2"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="20dp"
        android:src="@drawable/_3944"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/pin1" />

    <TextView
        android:layout_width="290dp"
        android:layout_height="wrap_content"
        android:text="Bandar Lampung, 35122"
        android:textAlignment="center"
        android:textColor="?attr/colorOnPrimary"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/pin2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/pin2"
        app:layout_constraintStart_toEndOf="@+id/pin2"
        app:layout_constraintTop_toTopOf="@id/pin2" />


    <View
        android:id="@+id/garis1"
        android:layout_width="360dp"
        android:layout_height="3dp"
        android:layout_marginTop="16dp"
        android:background="?attr/colorSecondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.49"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pin2" />


</androidx.constraintlayout.widget.ConstraintLayout>