<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg1"

    tools:context=".File1">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            android:layout_width="372dp"
            android:layout_marginTop="20dp"
            android:layout_height="197dp"
            android:layout_gravity="center"
            app:cardCornerRadius="20dp"
            >
            <ViewFlipper
                android:id="@+id/viewFlipper"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:autoStart="true">


                <ImageView
                    android:id="@+id/imageview1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/imageview2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/imageview3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/imageview4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scaleType="centerCrop" />
            </ViewFlipper>


            <TextView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:id="@+id/img1"
                android:visibility="invisible"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:id="@+id/img2"
                android:visibility="invisible"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:id="@+id/img3"
                android:visibility="invisible"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:id="@+id/img4"
                android:visibility="invisible"/>
        </androidx.cardview.widget.CardView>


        <TextView
            android:id="@+id/welcomee"
            android:layout_width="300dp"
            android:layout_height="70dp"
            android:layout_marginTop="10dp"
            tools:text=" Welcome to My App "
            android:textAlignment="center"
            android:layout_gravity="center"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="24dp"
            android:textStyle="bold" />
        <LinearLayout
            android:id="@+id/tampil"
            android:layout_width="250dp"
            android:layout_height="200dp"
            android:visibility="gone"
            tools:ignore="MissingConstraints"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:layout_marginTop="40dp">

            <ImageView
                android:id="@+id/kkembali"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_gravity="right"
                android:src="@drawable/hd_close_x_logo_red_icon_transparent_background_316319148421yuzw8i6jd" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Masukkan Password"
                android:textAlignment="center"
                android:textSize="24dp"
                android:textColor="?attr/colorOnPrimary"
                android:textStyle="bold"/>
            <EditText
                android:id="@+id/pw"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:inputType="textPassword"
                android:background="@drawable/backgroundlr"
                android:drawableRight="@drawable/ic_baseline_visibility_off_24"
                android:hint="Password"
                android:paddingHorizontal="15dp"
                android:textSize="24dp"
                android:textColor="?attr/colorOnPrimary"
                android:textStyle="bold"
                />
            <Button
                android:id="@+id/go"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Go"
                android:layout_marginTop="10dp"
                android:textSize="24dp"
                android:textColor="?attr/colorOnPrimary"
                android:textStyle="bold"
                />


        </LinearLayout>



        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/apaya"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="10dp">
                <LinearLayout
                    android:background="@drawable/backgroundkb"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_marginRight="10dp">

                    <TextView
                        android:id="@+id/ppk"
                        android:layout_marginStart="2dp"
                        android:textStyle="bold"
                        android:text="PPK Online"
                        android:textColor="?attr/colorOnPrimary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:background="@drawable/backgroundkb"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_marginRight="6dp">
                    <TextView
                        android:id="@+id/haccp"
                        android:layout_marginStart="2dp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnPrimary"
                        android:text="HACCP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:background="@drawable/backgroundkb"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_marginRight="6dp">
                    <TextView
                        android:id="@+id/ckib"
                        android:textColor="?attr/colorOnPrimary"
                        android:layout_marginStart="2dp"
                        android:textStyle="bold"
                        android:text="CKIB"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:background="@drawable/backgroundkb"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_marginRight="10dp">
                    <TextView
                        android:id="@+id/satudata"
                        android:textColor="?attr/colorOnPrimary"
                        android:layout_marginStart="2dp"
                        android:textStyle="bold"
                        android:text="KUSUKA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>


            </LinearLayout>

        </HorizontalScrollView>


        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/apaya2"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="50dp"
                android:layout_marginTop="10dp">
                <LinearLayout
                    android:background="@drawable/backgroundkb"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:layout_width="130dp"
                    android:layout_height="50dp"
                    android:layout_marginRight="20dp">
                    <TextView
                        android:id="@+id/organo"
                        android:layout_marginStart="3dp"
                        android:textStyle="bold"
                        android:text="Form Organoleptik"
                        android:textColor="?attr/colorOnPrimary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:background="@drawable/backgroundkb"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:layout_width="130dp"
                    android:layout_height="50dp"
                    android:layout_marginRight="20dp">
                    <TextView
                        android:id="@+id/sampel"
                        android:layout_marginStart="3dp"
                        android:textStyle="bold"
                        android:text="Permohonan Uji"
                        android:textColor="?attr/colorOnPrimary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>






            </LinearLayout>

        </HorizontalScrollView>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >

            <ScrollView
                android:layout_width="match_parent"

                android:layout_height="wrap_content">

                <GridLayout
                    android:id="@+id/grid_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="0dp"

                    android:columnCount="3"

                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="parent"
                    app:layout_constraintVertical_bias="0.0">

                    <androidx.cardview.widget.CardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_margin="16dp"
                        android:layout_marginTop="30dp"
                        app:cardCornerRadius="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/bkipm"
                                android:layout_width="62dp"
                                android:layout_height="62dp"
                                android:src="@drawable/kantorbkipm" />

                            <TextView

                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text="Profil BKIPM"
                                android:textColor="?attr/colorOnPrimary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_margin="16dp"
                        android:layout_marginTop="30dp"
                        app:cardCornerRadius="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"

                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/alamat"
                                android:layout_width="62dp"
                                android:layout_height="62dp"
                                android:src="@drawable/kontakalamat" />

                            <TextView

                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kontak Alamat"
                                android:textColor="?attr/colorOnPrimary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>





                    <androidx.cardview.widget.CardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_margin="16dp"
                        android:layout_marginTop="30dp"
                        app:cardCornerRadius="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"

                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/peraturank"
                                android:layout_width="62dp"
                                android:layout_height="62dp"
                                android:src="@drawable/_67755" />

                            <TextView

                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Regulasi"
                                android:textColor="?attr/colorOnPrimary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_margin="16dp"
                        android:layout_marginTop="0dp"
                        app:cardCornerRadius="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"

                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/pnbp"
                                android:layout_width="62dp"
                                android:layout_height="62dp"
                                android:src="@drawable/logo_harga_png" />

                            <TextView

                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text="Tarif PNBP"
                                android:textColor="?attr/colorOnPrimary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>



                    <androidx.cardview.widget.CardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_margin="16dp"
                        android:layout_marginTop="0dp"
                        app:cardCornerRadius="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"

                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/uploadimg"
                                android:layout_width="62dp"
                                android:layout_height="62dp"
                                android:src="@drawable/upload_icon_25" />

                            <TextView

                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text="Tutorial"
                                android:textColor="?attr/colorOnPrimary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_margin="16dp"
                        android:layout_marginTop="0dp"
                        app:cardCornerRadius="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"

                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/skm"
                                android:layout_width="62dp"
                                android:layout_height="62dp"
                                android:src="@drawable/iconkepuasan" />

                            <TextView

                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text="SKM"
                                android:textColor="?attr/colorOnPrimary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_margin="16dp"
                        android:layout_marginTop="0dp"
                        app:cardCornerRadius="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"

                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/satgashpik"
                                android:layout_width="62dp"
                                android:layout_height="62dp"
                                android:src="@drawable/wit"
                                />

                            <TextView

                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text="SATGAS HPIK"
                                android:textColor="?attr/colorOnPrimary"
                                android:textSize="14dp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>



                    <androidx.cardview.widget.CardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_margin="16dp"
                        android:layout_marginTop="0dp"
                        app:cardCornerRadius="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"

                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/seting"
                                android:layout_width="62dp"
                                android:layout_height="62dp"
                                android:src="@drawable/cogs" />

                            <TextView

                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Setting"
                                android:textColor="?attr/colorOnPrimary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>



                    <androidx.cardview.widget.CardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_margin="16dp"
                        android:layout_marginTop="0dp"
                        app:cardCornerRadius="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"

                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/logout"
                                android:layout_width="62dp"
                                android:layout_height="62dp"
                                android:src="@drawable/_596149" />

                            <TextView

                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Log Out"
                                android:textColor="?attr/colorOnPrimary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>



                </GridLayout>




            </ScrollView>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            >
            <LinearLayout

                android:gravity="center"
                android:layout_gravity="center"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginRight="8dp"
                >

                <ImageView
                    android:id="@+id/ig"
                    android:textStyle="bold"
                    android:src="@drawable/ig_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout

                android:gravity="center"
                android:layout_gravity="center"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginRight="8dp">

                <ImageView
                    android:id="@+id/yt"
                    android:layout_marginStart="2dp"
                    android:textStyle="bold"
                    android:src="@drawable/yt_icon"

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginRight="8dp">

                <ImageView
                    android:id="@+id/twit"
                    android:layout_marginStart="2dp"
                    android:textStyle="bold"
                    android:src="@drawable/tw_icon"

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginRight="8dp">

                <ImageView
                    android:id="@+id/fb"
                    android:layout_marginStart="2dp"
                    android:textStyle="bold"
                    android:src="@drawable/fb_icon"

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginRight="8dp">

                <ImageView
                    android:id="@+id/wa"
                    android:layout_marginStart="2dp"
                    android:textStyle="bold"
                    android:src="@drawable/wa_icon"

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>


        </LinearLayout>



    </LinearLayout>

</ScrollView>